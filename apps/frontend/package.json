{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NUXT_DEVTOOLS_ENABLED=false nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.86",
    "@nuxt/ui": "^4.9.0",
    "@pinia/colada-nuxt": "latest",
    "@pinia/nuxt": "latest",
    "@vueuse/nuxt": "latest",
    "nuxt": "^4.4.8",
    "pinia": "latest",
    "tailwindcss": "^4.3.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "latest",
    "@vitest/coverage-v8": "latest",
    "@vue/test-utils": "latest",
    "eslint": "^10.5.0",
    "happy-dom": "latest",
    "lint-staged": "latest",
    "simple-git-hooks": "latest",
    "typescript": "^6.0.3",
    "vitest": "latest",
    "vue-tsc": "^3.3.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": "eslint --fix"
  },
  "packageManager": "pnpm@11.8.0",
  "pnpm": {
    "onlyBuiltDependencies": ["simple-git-hooks"]
  }
}
